# Server
PORT=3030
JWT_SECRET=change-me-in-production

# Database
DATABASE_URL=postgresql://user:password@host:5432/postgres

# OAuth — LINE
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth redirect allow-list (comma separated)
ALLOWED_REDIRECT_URLS=http://localhost:3000

# Ollama (AI-generated medical precautions)
# For Ollama Cloud, use https://ollama.com and set OLLAMA_API_KEY.
# For local Ollama, use http://localhost:11434 and leave OLLAMA_API_KEY empty.
OLLAMA_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_API_KEY=
