{
  "name": "oonjai-core-service",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:bin": "bun run build:bin:linux-x64 && bun run build:bin:linux-arm64 && bun run build:bin:darwin-x64 && bun run build:bin:darwin-arm64 && bun run build:bin:windows-x64",
    "build:bin:linux-x64": "bun build ./src/index.ts --compile --target=bun-linux-x64 --outfile ./dist/oonjai-core-service-linux-x64",
    "build:bin:linux-arm64": "bun build ./src/index.ts --compile --target=bun-linux-arm64 --outfile ./dist/oonjai-core-service-linux-arm64",
    "build:bin:darwin-x64": "bun build ./src/index.ts --compile --target=bun-darwin-x64 --outfile ./dist/oonjai-core-service-darwin-x64",
    "build:bin:darwin-arm64": "bun build ./src/index.ts --compile --target=bun-darwin-arm64 --outfile ./dist/oonjai-core-service-darwin-arm64",
    "build:bin:windows-x64": "bun build ./src/index.ts --compile --target=bun-windows-x64 --outfile ./dist/oonjai-core-service-windows-x64.exe",
    "prepare": "husky",
    "dev": "DEBUG=true bun serve",
    "serve": "bun run src/index.ts",
    "test": "bun test",
    "test-suite": "http-server ./debug",
    "seed:activities": "bun run scripts/seed-activities.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/bun": "latest",
    "@types/node": "^25.2.2",
    "bun-types": "^1.3.12",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,mdx}": [
      "eslint --fix"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "postgres": "^3.4.9"
  }
}
